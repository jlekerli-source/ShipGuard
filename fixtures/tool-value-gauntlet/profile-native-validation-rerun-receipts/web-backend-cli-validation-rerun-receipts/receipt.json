            },
            {
              "path": "validationReceipts.blockedCount",
              "equals": 1
            },
            {
              "path": "validationRerunReceipts.pairCount",
              "equals": 1
            },
            {
              "path": "validationRerunReceipts.blockedPairCount",
              "equals": 1
            }
          ]
        },
        {
          "path": "backend-plan-blocked/backend-plan.md",
          "type": "markdown",
          "requiredPhrases": [
            "Validation Rerun Receipts",
            "blocked_until_repaired",
            "Rerun template"
          ],
          "forbidLocalPaths": true
        }
      ]
    },
    {
      "id": "backend-repair-lint-signal",
      "display": "fixture repair: add pyproject ruff signal, then run shipguard version",
      "prepareFiles": [
