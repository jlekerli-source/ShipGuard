  "remediationPairs": [
    {
      "id": "web-lint-smallest-repair",
      "blockedCommandId": "web-blocked-lint-plan",
      "repairCommandIds": [
        "web-repair-lint-script"
      ],
      "rerunCommandId": "web-rerun-lint-plan",
      "smallestRepair": "Add only package.json scripts.lint, then rerun WebForge and require blockedCount to clear."
    },
    {
      "id": "backend-lint-smallest-repair",
      "blockedCommandId": "backend-blocked-lint-plan",
      "repairCommandIds": [
        "backend-repair-lint-signal"
      ],
      "rerunCommandId": "backend-rerun-lint-plan",
      "smallestRepair": "Add only a pyproject Ruff signal, then rerun ServiceForge and require blockedCount to clear."
    },
    {
      "id": "cli-help-smallest-repair",
      "blockedCommandId": "cli-blocked-help-plan",
      "repairCommandIds": [
        "cli-repair-bin-entry"
      ],
      "rerunCommandId": "cli-rerun-help-plan",
