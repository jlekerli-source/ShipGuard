{
  "id": "web-backend-cli-validation-rerun-receipts",
  "kind": "profile-native-validation-rerun-receipt",
  "surface": "ShipGuard profile-native validation rerun path",
  "selectedSkill": "ios-shipguard",
  "selectedMode": "profile-native-validation-rerun-receipts",
  "trigger": "User asks whether ShipGuard can prove a blocked profile validation lane shows the smallest repair and passes after rerunning the plan, without editing private apps.",
  "sourcePaths": [
    "bin/shipguard",
    "scripts/profile_fix_plan.py",
    "scripts/tool_value_gauntlet.py",
    "docs/template-profiles.md",
    "docs/command-matrix.md",
    "docs/cli.md",
    "tests/profile_validation_rerun_receipts_test.sh",
    "tests/tool_value_gauntlet_test.sh"
  ],
  "expectedSourcePhrases": [
    "validationRerunReceipts",
    "read-only repair/rerun guidance",
    "profile-native validation rerun receipts"
  ],
  "scopeBoundary": {
    "shipguardOnly": true,
    "targetAppsReadOnly": true,
    "privateAppDetailsAllowed": false,
    "commandsExecuted": false,
    "repairsAreFixtureLocal": true
  },
  "commands": [
    {
      "id": "web-blocked-lint-plan",
      "display": "./bin/shipguard web plan --report <web-audit> --target <fresh-web-target> --out <receipt-out>/web-plan-blocked --shipguard-eval --shareable",
      "prepareFiles": [
        {
          "path": "target-web/package.json",
          "text": "{\n  \"scripts\": {},\n  \"dependencies\": {\"next\": \"latest\"}\n}\n"
        },
        {
          "path": "web-audit/web-audit.json",
          "text": "{\n  \"schemaVersion\": 1,\n  \"tool\": \"shipguard web audit\",\n  \"surface\": \"ShipGuard WebScan\",\n  \"profile\": \"web\",\n  \"generatedAt\": \"2026-06-18T00:00:00Z\",\n  \"status\": \"pass\",\n  \"target\": {\"root\": \"<target-repo>\", \"fileCountScanned\": 2},\n  \"recommendedFirstCommands\": [\"shipguard web audit --path . --out /tmp/shipguard-web-audit\"],\n  \"recommendedValidation\": [\"npm run lint\"],\n  \"findings\": [],\n  \"reportQualityQuestions\": [\"Does ShipGuard web plan prove blocked validation lanes can be repaired and rerun?\"]\n}\n"
        }
      ],
      "args": [
        "web",
        "plan",
        "--report",
        "{out}/web-audit",
        "--out",
        "{out}/web-plan-blocked",
        "--target",
        "{out}/target-web",
        "--shipguard-eval",
        "--shareable"
      ],
      "blockingProof": {
        "artifact": "web-plan-blocked/web-plan.json",
        "path": "validationReceipts.blockedCount",
        "min": 1
      },
      "artifacts": [
        {
          "path": "web-plan-blocked/web-plan.json",
          "type": "json",
          "requiredJsonKeys": [
            "tool",
            "profile",
            "validationReceipts",
            "validationRerunReceipts"
          ],
          "requiredNonEmptyJsonPaths": [
            "validationRerunReceipts.pairs"
          ],
          "requiredValues": [
            {
              "path": "tool",
              "equals": "shipguard web plan"
            },
            {
              "path": "validationReceipts.blockedCount",
              "equals": 1
            },
            {
              "path": "validationRerunReceipts.pairCount",
              "equals": 1
            },
            {
              "path": "validationRerunReceipts.blockedPairCount",
              "equals": 1
            }
          ]
        },
        {
          "path": "web-plan-blocked/web-plan.md",
          "type": "markdown",
          "requiredPhrases": [
            "Validation Rerun Receipts",
            "blocked_until_repaired",
            "Rerun template"
          ],
          "forbidLocalPaths": true
        }
      ]
    },
    {
      "id": "web-repair-lint-script",
      "display": "fixture repair: add package.json scripts.lint, then run shipguard version",
      "prepareFiles": [
        {
          "path": "target-web/package.json",
          "text": "{\n  \"scripts\": {\"lint\": \"eslint .\"},\n  \"dependencies\": {\"next\": \"latest\"}\n}\n"
        }
      ],
      "args": [
        "version"
      ],
      "expectedOutputPhrases": [
        "3."
      ]
    },
    {
      "id": "web-rerun-lint-plan",
      "display": "./bin/shipguard web plan --report <web-audit> --target <repaired-web-target> --out <receipt-out>/web-plan-rerun --shipguard-eval --shareable",
      "args": [
        "web",
        "plan",
        "--report",
        "{out}/web-audit",
        "--out",
        "{out}/web-plan-rerun",
        "--target",
        "{out}/target-web",
        "--shipguard-eval",
        "--shareable"
      ],
      "artifacts": [
        {
          "path": "web-plan-rerun/web-plan.json",
          "type": "json",
          "requiredJsonKeys": [
            "tool",
            "profile",
            "validationReceipts",
            "validationRerunReceipts"
          ],
          "requiredValues": [
            {
              "path": "tool",
              "equals": "shipguard web plan"
            },
            {
              "path": "validationReceipts.blockedCount",
              "equals": 0
            },
            {
              "path": "validationRerunReceipts.pairCount",
              "equals": 0
            }
          ]
        }
      ]
    },
    {
      "id": "backend-blocked-lint-plan",
      "display": "./bin/shipguard backend plan --report <backend-audit> --target <fresh-backend-target> --out <receipt-out>/backend-plan-blocked --shipguard-eval --shareable",
      "prepareFiles": [
        {
          "path": "target-backend/pyproject.toml",
          "text": "[project]\nname = \"demo-service\"\n"
        },
        {
          "path": "backend-audit/backend-audit.json",
          "text": "{\n  \"schemaVersion\": 1,\n  \"tool\": \"shipguard backend audit\",\n  \"surface\": \"ShipGuard ServiceRadar\",\n  \"profile\": \"backend\",\n  \"generatedAt\": \"2026-06-18T00:00:00Z\",\n  \"status\": \"pass\",\n  \"target\": {\"root\": \"<target-repo>\", \"fileCountScanned\": 2},\n  \"recommendedFirstCommands\": [\"shipguard backend audit --path . --out /tmp/shipguard-backend-audit\"],\n  \"recommendedValidation\": [\"lint/typecheck\"],\n  \"findings\": [],\n  \"reportQualityQuestions\": [\"Does ShipGuard backend plan prove blocked validation lanes can be repaired and rerun?\"]\n}\n"
        }
