{
  "id": "web-backend-cli-proof-handoffs",
  "kind": "profile-native-proof-handoff-receipt",
  "surface": "ShipGuard profile-native proof handoff packets",
  "selectedSkill": "ios-shipguard",
  "selectedMode": "profile-native-proof-handoff-receipts",
  "trigger": "User asks whether repaired ShipGuard web, backend, and CLI plans become copy-ready evidence packets for Codex and maintainers without editing private apps.",
  "sourcePaths": [
    "bin/shipguard",
    "scripts/profile_fix_plan.py",
    "scripts/tool_value_gauntlet.py",
    "docs/template-profiles.md",
    "docs/command-matrix.md",
    "docs/cli.md",
    "tests/profile_proof_handoff_receipts_test.sh",
    "tests/tool_value_gauntlet_test.sh"
  ],
  "expectedSourcePhrases": [
    "proofHandoff",
    "Proof Handoff Packet",
    "profile-native proof handoff receipts"
  ],
  "scopeBoundary": {
    "shipguardOnly": true,
    "targetAppsReadOnly": true,
    "privateAppDetailsAllowed": false,
    "commandsExecuted": false,
    "repairsAreFixtureLocal": true
  },
  "commands": [
    {
      "id": "web-copy-ready-proof-handoff",
      "display": "./bin/shipguard web plan --report <web-audit> --target <repaired-web-target> --out <receipt-out>/web-plan-ready --shipguard-eval --shareable",
      "prepareFiles": [
        {
          "path": "target-web/package.json",
          "text": "{\n  \"scripts\": {\"lint\": \"eslint .\"},\n  \"dependencies\": {\"next\": \"latest\"}\n}\n"
        },
        {
          "path": "web-audit/web-audit.json",
          "text": "{\n  \"schemaVersion\": 1,\n  \"tool\": \"shipguard web audit\",\n  \"surface\": \"ShipGuard WebScan\",\n  \"profile\": \"web\",\n  \"generatedAt\": \"2026-06-18T00:00:00Z\",\n  \"status\": \"pass\",\n  \"target\": {\"root\": \"<target-repo>\", \"fileCountScanned\": 2},\n  \"recommendedFirstCommands\": [\"shipguard web audit --path . --out /tmp/shipguard-web-audit\"],\n  \"recommendedValidation\": [\"npm run lint\"],\n  \"findings\": [],\n  \"reportQualityQuestions\": [\"Does ShipGuard web plan produce a copy-ready proof handoff after validation blockers clear?\"]\n}\n"
        }
      ],
      "args": [
        "web",
        "plan",
        "--report",
        "{out}/web-audit",
        "--out",
        "{out}/web-plan-ready",
        "--target",
        "{out}/target-web",
        "--shipguard-eval",
        "--shareable"
      ],
      "artifacts": [
        {
          "path": "web-plan-ready/web-plan.json",
          "type": "json",
          "requiredJsonKeys": [
            "tool",
            "profile",
            "validationReceipts",
            "validationRerunReceipts",
            "proofHandoff"
          ],
          "requiredNonEmptyJsonPaths": [
            "proofHandoff.commandsToCapture",
            "proofHandoff.handoffMarkdown"
          ],
          "requiredValues": [
            {
              "path": "tool",
              "equals": "shipguard web plan"
            },
            {
              "path": "validationReceipts.blockedCount",
              "equals": 0
            },
            {
              "path": "validationRerunReceipts.pairCount",
              "equals": 0
            },
            {
              "path": "proofHandoff.status",
              "equals": "copy_ready"
            },
            {
              "path": "proofHandoff.copyReady",
              "equals": true
            },
            {
              "path": "proofHandoff.scopeBoundary.implementationAuthorized",
              "equals": false
            }
          ]
        },
        {
          "path": "web-plan-ready/web-plan.md",
          "type": "markdown",
          "requiredPhrases": [
            "Proof Handoff Packet",
            "Copy-ready: true",
            "Copy-Ready Markdown",
            "npm run lint"
          ],
          "forbidLocalPaths": true
        }
      ]
    },
