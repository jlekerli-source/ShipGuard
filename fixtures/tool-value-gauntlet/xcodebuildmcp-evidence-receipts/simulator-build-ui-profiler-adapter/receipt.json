{
  "id": "simulator-build-ui-profiler-adapter",
  "kind": "xcodebuildmcp-evidence-receipt",
  "surface": "ShipGuard XcodeBuildMCP Evidence Adapter",
  "selectedMode": "value-gauntlet xcodebuildmcp evidence receipts",
  "trigger": "Prove XcodeBuildMCP build/run, UI snapshot, screenshot, log, and profiler proof can attach to a ShipGuard agent trace timeline without editing target apps.",
  "sourcePaths": [
    "bin/shipguard",
    "scripts/agent_trace.py",
    "scripts/tool_value_gauntlet.py",
    "tests/agent_trace_test.sh",
    "docs/agent-trace.md"
  ],
  "expectedSourcePhrases": [
    "xcodeBuildMCPEvidence",
    "xcodebuildmcp-evidence",
    "XcodeBuildMCP Evidence",
    "runtimeXcodeBuildMCPEvidenceAdapter",
    "xcodeBuildMCPEvidenceReceipts"
  ],
  "scopeBoundary": {
    "shipguardOnly": true,
    "targetAppsReadOnly": true,
    "privateAppsUsed": false,
    "inputs": [
      "synthetic Codex-style trace",
      "synthetic XcodeBuildMCP build/run log",
      "synthetic UI snapshot JSON",
      "synthetic screenshot marker file",
      "synthetic runtime log",
      "synthetic profiler trace"
    ]
  },
  "prepareFiles": [
    {
      "path": "fixture/Sources/XcodeAdapterFixture/App.swift",
      "text": "public struct XcodeAdapterFixture {}\n"
    },
    {
      "path": "diffs/good.diff",
      "text": "diff --git a/Sources/XcodeAdapterFixture/App.swift b/Sources/XcodeAdapterFixture/App.swift\n--- a/Sources/XcodeAdapterFixture/App.swift\n+++ b/Sources/XcodeAdapterFixture/App.swift\n@@ -1 +1,2 @@\n public struct XcodeAdapterFixture {}\n+// xcodebuildmcp adapter fixture\n"
    },
    {
      "path": "logs/swift-test.log",
      "text": "swift test passed for xcodebuildmcp adapter fixture\n"
    },
    {
      "path": "logs/v2-validation-receipt.json",
      "text": "{\n  \"schemaVersion\": \"2.0\",\n  \"receiptId\": \"v2-xcodebuildmcp-swift-test\",\n  \"receiptType\": \"validation\",\n  \"requirementId\": \"swift-test\",\n  \"command\": \"swift test\",\n  \"exitCode\": 0,\n  \"status\": \"pass\",\n  \"startedAt\": \"2099-01-01T00:00:00Z\",\n  \"completedAt\": \"2099-01-01T00:00:10Z\",\n  \"repositoryCommit\": \"synthetic\",\n  \"environment\": \"local-cli\",\n  \"artifact\": {\"path\": \"swift-test.log\"},\n  \"scope\": [\"xcodebuildmcp-adapter-fixture\"]\n}\n"
    },
    {
      "path": "trace.json",
      "text": "{\n  \"adapter\": \"codex\",\n  \"threadId\": \"synthetic-codex-thread\",\n  \"taskId\": \"TASK-XCODE-001\",\n  \"agentBudget\": {\"workersRequested\": 2, \"maxWorkers\": 5, \"recursiveSpawning\": false},\n  \"events\": [\n    {\"type\": \"prompt\", \"role\": \"user\", \"text\": \"Attach XcodeBuildMCP proof to the trace.\"},\n    {\"type\": \"tool_call\", \"tool\": \"xcodebuildmcp.build_run_sim\", \"command\": \"build_run_sim\"},\n    {\"type\": \"receipt\", \"receiptId\": \"v2-xcodebuildmcp-swift-test\", \"path\": \"logs/v2-validation-receipt.json\"},\n    {\"type\": \"verdict\", \"status\": \"pass\", \"path\": \"verify/shipguard-verdict.json\"},\n    {\"type\": \"next_action\", \"text\": \"Generate NEXT_GOAL for Expo/EAS.\"}\n  ]\n}\n"
    },
    {
      "path": "xcodebuildmcp/session-build.log",
      "text": "session_show_defaults\nsession_set_defaults with workspace=DemoShipGuardApp.xcworkspace, scheme=DemoShipGuardApp, simulator=iPhone 15\nbuild_run_sim\n** BUILD SUCCEEDED **\nLaunching DemoShipGuardApp\n"
    },
    {
      "path": "xcodebuildmcp/describe-ui.json",
      "text": "{\"tool\":\"snapshot_ui\",\"elements\":[{\"elementRef\":\"button.start\",\"label\":\"Start\"}]}\n"
    },
    {
      "path": "xcodebuildmcp/screenshot.png",
      "text": "synthetic png proof marker\n"
    },
    {
      "path": "xcodebuildmcp/runtime.log",
      "text": "start_sim_log_cap\nruntime log contains focused os_log output\nstop_sim_log_cap\n"
    },
    {
      "path": "xcodebuildmcp/profile.trace",
      "text": "xctrace record --template 'Animation Hitches'\nTime Profiler and Animation Hitches summaries preserved.\n"
    }
  ],
  "commands": [
    {
      "id": "prepare-xcodebuildmcp-trace-task",
      "display": "./bin/shipguard prepare xcodebuildmcp adapter fixture",
      "args": [
        "prepare",
        "Exercise XcodeBuildMCP evidence adapter",
        "--path",
        "{out}/fixture",
        "--out",
        "{out}/prepare",
        "--profile",
        "ios",
        "--allowed",
        "Sources/**",
        "--validation",
        "swift test"
      ],
      "artifacts": [
        {
          "path": "prepare/shipguard-task.json",
          "type": "json",
          "requiredJsonKeys": ["tool", "taskId", "validationContract", "authorizedFiles"],
          "requiredNonEmptyJsonPaths": ["validationContract.required"],
          "requiredValues": [
            {"path": "tool", "equals": "shipguard prepare"}
          ]
        }
      ]
    },
    {
      "id": "agent-trace-xcodebuildmcp-proof-pass",
      "display": "./bin/shipguard agent trace --xcodebuildmcp-evidence --run-verify",
      "args": [
        "agent",
        "trace",
        "--trace",
        "{out}/trace.json",
        "--task",
        "{out}/prepare/shipguard-task.json",
        "--diff",
        "{out}/diffs/good.diff",
        "--evidence",
        "{out}/logs/v2-validation-receipt.json",
        "--xcodebuildmcp-evidence",
        "{out}/xcodebuildmcp",
        "--run-verify",
        "--out",
        "{out}/agent-trace",
        "--shipguard-eval",
        "--shareable"
      ],
      "artifacts": [
        {
          "path": "agent-trace/agent-trace.json",
          "type": "json",
          "requiredJsonKeys": ["tool", "status", "traceSummary", "taskTrace", "xcodeBuildMCPEvidence", "verifyHandoff", "receiptHandoff"],
          "requiredNonEmptyJsonPaths": ["taskTrace.xcodeBuildMCPEvidenceTimeline", "xcodeBuildMCPEvidence.signals"],
          "requiredValues": [
            {"path": "tool", "equals": "shipguard agent trace"},
            {"path": "status", "equals": "pass"},
            {"path": "xcodeBuildMCPEvidence.status", "equals": "pass"},
            {"path": "xcodeBuildMCPEvidence.summary.sessionDefaultsProof", "equals": true},
            {"path": "xcodeBuildMCPEvidence.summary.buildRunProof", "equals": true},
            {"path": "xcodeBuildMCPEvidence.summary.uiSnapshotProof", "equals": true},
            {"path": "xcodeBuildMCPEvidence.summary.screenshotProof", "equals": true},
            {"path": "xcodeBuildMCPEvidence.summary.logProof", "equals": true},
            {"path": "xcodeBuildMCPEvidence.summary.profilerProof", "equals": true},
            {"path": "verifyHandoff.status", "equals": "pass"},
            {"path": "traceSummary.xcodeBuildMCPEvidenceCount", "equals": 6}
          ],
          "forbidLocalPaths": true
        },
        {
          "path": "agent-trace/agent-trace.md",
          "type": "markdown",
          "requiredPhrases": ["# ShipGuard Agent Trace", "XcodeBuildMCP Evidence", "Build/run proof", "Profiler proof"],
          "forbidLocalPaths": true
        },
        {
          "path": "agent-trace/agent-trace-receipt.json",
          "type": "json",
          "requiredJsonKeys": ["schemaVersion", "receiptId", "receiptType", "artifact", "scope"],
          "requiredValues": [
            {"path": "receiptType", "equals": "runtime"},
            {"path": "requirementId", "equals": "xcodebuildmcp-evidence-adapter"},
            {"path": "artifact.path", "equals": "agent-trace.json"}
          ]
        }
      ]
    },
    {
      "id": "codex-trace-xcodebuildmcp-proof-pass",
      "display": "./bin/shipguard codex trace --xcodebuildmcp-evidence",
      "args": [
        "codex",
        "trace",
        "--trace",
        "{out}/trace.json",
        "--xcodebuildmcp-evidence",
        "{out}/xcodebuildmcp",
        "--out",
        "{out}/codex-trace",
        "--shipguard-eval",
        "--shareable"
      ],
      "artifacts": [
        {
          "path": "codex-trace/agent-trace.json",
          "type": "json",
          "requiredJsonKeys": ["tool", "adapter", "xcodeBuildMCPEvidence", "taskTrace"],
          "requiredNonEmptyJsonPaths": ["taskTrace.xcodeBuildMCPEvidenceTimeline"],
          "requiredValues": [
            {"path": "tool", "equals": "shipguard codex trace"},
            {"path": "adapter.type", "equals": "codex"},
            {"path": "xcodeBuildMCPEvidence.status", "equals": "pass"},
            {"path": "xcodeBuildMCPEvidence.summary.profilerProof", "equals": true}
          ],
          "forbidLocalPaths": true
        }
      ]
    }
  ]
}
